{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "installCommand": "pnpm install",
  "buildCommand": "pnpm db:migrate && pnpm --filter @digitify/db db:generate && pnpm --filter @digitify/web build",
  "outputDirectory": "apps/web/.next",
  "crons": [
    {
      "path": "/api/cron/drip",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/bookings-sync",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/social-publish",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/media-reconcile",
      "schedule": "0 10 * * *"
    }
  ]
}
