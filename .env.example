# ===== DATABASE =====
DATABASE_URL="postgresql://digitify:digitify_dev@localhost:5432/digitify_leads"
REDIS_URL="redis://localhost:6379"

# ===== AUTHENTICATION =====
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
# Required in production: encrypts sensitive values stored in `settings` (API keys, SMTP/IMAP passwords)
SETTINGS_ENCRYPTION_KEY=""

# ===== AI PROVIDERS (configured via Settings > Integraties) =====
# These can also be set via the admin UI under Settings > Integraties
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ===== GOOGLE PLACES API =====
GOOGLE_PLACES_API_KEY=""

# ===== GOOGLE CALENDAR OAUTH =====
# Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized redirect URI:
#   http://localhost:3000/api/integrations/google-calendar/callback
#   https://leads.digitify.be/api/integrations/google-calendar/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===== EMAIL =====
# Email provider: smtp | console
EMAIL_PROVIDER="smtp"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# IMAP (optional, for inbox feature)
IMAP_HOST=""
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASS=""
IMAP_TLS="true"

# ===== DEPLOYMENT =====
# Multi-domain: set this for each deployment environment
# Used for correct URL generation in emails, PDFs, booking links etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# White-label: override the default app name (optional)
NEXT_PUBLIC_APP_NAME=""
