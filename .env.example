# ===== DATABASE =====
DATABASE_URL="postgresql://digitify:digitify_dev@localhost:5432/digitify_leads"
DIRECT_URL="postgresql://digitify:digitify_dev@localhost:5432/digitify_leads"
REDIS_URL="redis://localhost:6379"
# Node/tRPC + public API routes: Redis TCP when REDIS_URL is set.
# Edge middleware (login/register): set Upstash REST for multi-instance Vercel:
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""
# Staging/production: enable after two OWNER smoke-test (cross-tenant reads must return 0 rows)
# Required in production (validated at server startup)
# ENABLE_WORKSPACE_RLS="true"
# Single-tenant: marketing footer + registratie-notificaties (OWNER user id)
# PUBLIC_MARKETING_WORKSPACE_ID=""
# Owner workspace for public marketing footer + SEO (sitemap, meta). Falls back to default tenant.
# REGISTRATION_NOTIFY_WORKSPACE_ID=""
# Second OWNER for RLS staging (created by pnpm db:seed; password defaults to SEED_ADMIN_PASSWORD)
# SEED_RLS_OWNER_B_EMAIL="owner-b@digitify.local"
# SEED_RLS_OWNER_B_PASSWORD=""
# After deploy: copy legacy owner settings to workspace:* keys
# pnpm db:migrate-workspace-settings
# pnpm db:migrate-legacy-templates
# Vercel Blob — uploads (logo, branding); required in production on Vercel
# BLOB_READ_WRITE_TOKEN=""

# Error tracking (optional — Sentry)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# RUN_DB_INTEGRATION=1 ENABLE_WORKSPACE_RLS=true pnpm test:integration
# ENABLE_WORKSPACE_RLS=true pnpm rls:smoke
# PLAYWRIGHT_BASE_URL=http://localhost:3001 PLAYWRIGHT_SKIP_WEBSERVER=1 pnpm test:e2e

# ===== AUTHENTICATION =====
NEXTAUTH_URL="http://localhost:3000"
# Min. 32 characters (validated at server startup via src/instrumentation.ts)
NEXTAUTH_SECRET="change-me-use-at-least-32-characters-long"
# Required in production: encrypts sensitive values stored in `settings` (API keys, SMTP/IMAP passwords)
# Min. 32 characters, not the placeholder below
SETTINGS_ENCRYPTION_KEY=""

# ===== AI PROVIDERS (configured via Settings > Integraties) =====
# These can also be set via the admin UI under Settings > Integraties
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ===== GOOGLE PLACES API =====
GOOGLE_PLACES_API_KEY=""

# ===== GOOGLE CALENDAR OAUTH =====
# Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized redirect URI:
#   http://localhost:3000/api/integrations/google-calendar/callback
#   https://leads.digitify.be/api/integrations/google-calendar/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===== META (FACEBOOK / INSTAGRAM) OAUTH =====
# Redirect URI:
#   http://localhost:3000/api/integrations/meta/callback
#   https://leads.digitify.be/api/integrations/meta/callback
# Optional API version override (default used by app: v24.0)
META_GRAPH_API_VERSION="v24.0"
# Login flow: facebook (default, Page-linked IG) or instagram (Instagram Login product)
META_OAUTH_LOGIN_MODE="facebook"
# standard = Pages + IG publish | minimal = pages_show_list + instagram_basic + instagram_content_publish only
META_OAUTH_SCOPE_LEVEL="standard"
# Include Marketing API scopes on OAuth (ads_read, ads_management, business_management)
META_OAUTH_INCLUDE_ADS="false"
# Meta ad set targeting: 0 = Advantage+ audience uit (default), 1 = aan
META_ADS_ADVANTAGE_AUDIENCE="0"
# Optional full scope override (comma-separated). When set, LOGIN_MODE/INCLUDE_ADS are ignored.
# Facebook Login default:
# pages_show_list,pages_read_engagement,pages_manage_posts,instagram_basic,instagram_content_publish
META_OAUTH_SCOPES=""

# ===== GOOGLE ADS API =====
# Platform-wide developer token from https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=""
# Optional MCC (manager) customer id — 10 digits, no dashes; can also set per workspace in Integraties
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""
# Advantage+ audience for Google is N/A; budget guard default uses ads.google_max_daily_budget_cents in workspace settings

# ===== EMAIL =====
# Email provider: smtp | console
EMAIL_PROVIDER="smtp"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# IMAP (optional, for inbox feature)
IMAP_HOST=""
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASS=""
IMAP_TLS="true"

# ===== CRON (required in production) =====
# Vercel cron jobs must send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""
# Local dev only — allow /api/cron/* without bearer when CRON_SECRET is unset
CRON_ALLOW_UNSIGNED_DEV="1"

# ===== OPS (optional) =====
# One-time DB bootstrap (disabled in production unless ALLOW_BOOTSTRAP_DB=1)
# BOOTSTRAP_DB_TOKEN=""
# ALLOW_BOOTSTRAP_DB="1"
# EMAIL_TRACKING_TOKEN_SECRET=""  # defaults to NEXTAUTH_SECRET

# ===== DEPLOYMENT =====
# Multi-domain: set this for each deployment environment
# Used for correct URL generation in emails, PDFs, booking links etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# White-label: override the default app name (optional)
NEXT_PUBLIC_APP_NAME=""
