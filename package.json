{
  "name": "digitify-lead-search",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "pnpm --filter @digitify/web exec tsc --noEmit",
    "db:generate": "turbo db:generate",
    "db:migrate": "pnpm --filter @digitify/db db:migrate",
    "db:migrate-metadata": "pnpm --filter @digitify/db db:migrate-metadata",
    "db:migrate-workspace-settings": "pnpm --filter @digitify/db db:migrate-workspace-settings",
    "db:migrate-legacy-templates": "pnpm --filter @digitify/db db:migrate-legacy-templates",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "db:studio": "pnpm --filter @digitify/db studio",
    "clean": "turbo clean",
    "test": "turbo test && pnpm --filter @digitify/web test",
    "test:integration": "pnpm --filter @digitify/api test:integration",
    "rls:smoke": "pnpm --filter @digitify/db db:rls-smoke",
    "setup:db": "bash scripts/setup-production-db.sh",
    "check:release": "bash scripts/check-release.sh",
    "db:resolve-init": "bash scripts/resolve-init-migration.sh",
    "test:redis": "pnpm --filter @digitify/api test:redis",
    "test:e2e": "pnpm --filter @digitify/web test:e2e"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
